msgid "Use a dark background instead of a light one."
msgstr "Usa uno sfondo scuro invece di uno chiaro."

#. #-#-#-#-#  bambam-man.pot (PACKAGE VERSION)  #-#-#-#-#
#. type: Plain text
#: bambam.py:573 bambam.6:20
msgid "Start muted."
